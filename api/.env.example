# ── DealForge Coordination API — Environment Variables ──────────────────────

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://dealforge:dealforge@localhost:5432/dealforge?schema=public"

# Redis (caching & pub/sub)
REDIS_URL="redis://localhost:6379"

# Gemini (via OpenAI-compatible endpoint) — powers the NegotiationEngine
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash-preview-05-20"

# Blockchain RPCs
BASE_RPC_URL="https://mainnet.base.org"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# DealForge contract (deploy first, then paste address)
DEALFORGE_CONTRACT_ADDRESS="0x..."

# JWT (for future session tokens; must be ≥32 chars)
JWT_SECRET="change-me-in-production-min-32-chars"

# IPFS pinning (optional for dev; required for prod)
PINATA_API_KEY=""
PINATA_SECRET_KEY=""
