# ── DealForge Coordination API — Environment Variables ──────────────────────

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://dealforge:dealforge@localhost:5432/dealforge?schema=public"

# Redis (caching & pub/sub)
REDIS_URL="redis://localhost:6379"

# x402 / AgentCash paid endpoints
X402_ENABLED="false"
X402_PAY_TO_ADDRESS="0x0000000000000000000000000000000000000000"
X402_NETWORK="base-sepolia"
X402_MATCHES_PRICE="$0.01"
X402_EVALUATE_PRICE="$0.05"
CDP_API_KEY_ID="your-cdp-api-key-id"
CDP_API_KEY_SECRET="your-cdp-api-key-secret"

# LLM provider selection
LLM_PROVIDER="venice"

# Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY="AIza..."

# Venice AI (OpenAI-compatible)
VENICE_INFERENCE_KEY="your-venice-inference-key"

# Optional overrides; defaults depend on LLM_PROVIDER
# Gemini defaults:
#   LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
#   LLM_MODEL="gemini-2.5-flash-preview-05-20"
# Venice defaults:
#   LLM_BASE_URL="https://api.venice.ai/api/v1"
#   LLM_MODEL="zai-org-glm-4.7"
# LLM_BASE_URL=""
# LLM_MODEL=""

# Blockchain RPCs
BASE_RPC_URL="https://mainnet.base.org"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# JWT (for future session tokens; must be ≥32 chars)
JWT_SECRET="change-me-in-production-min-32-chars"

# IPFS — Pinata (https://app.pinata.cloud/developers/api-keys)
PINATA_JWT="eyJhb..."
PINATA_GATEWAY="your-gateway.mypinata.cloud"
